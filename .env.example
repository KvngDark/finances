# Copie este arquivo para .env e preencha com os dados do TiDB.
# O app tambem aceita DATABASE_URL=mysql://usuario:senha@host:4000/banco

PORT=3000
HOST=0.0.0.0

TIDB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=seu_usuario
TIDB_PASSWORD=sua_senha
TIDB_DATABASE=financeiro_despachante
TIDB_SSL=true
TIDB_AUTO_SCHEMA=true

# Opcional: caminho local de um certificado CA, se sua conta TiDB exigir.
# TIDB_CA_CERT=C:\caminho\para\ca.pem
